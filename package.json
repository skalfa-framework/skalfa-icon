{
  "name": "@skalfa/skalfa-icon",
  "version": "1.0.4",
  "description": "Custom SVG icon components for the Skalfa ecosystem. Upload SVG files and generate type-safe React icon components.",
  "keywords": ["skalfa", "skalfa-icon", "svg", "icon", "react"],
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "skalfa-icon": "./scripts/generate.ts"
  },
  "files": ["dist", "src", "icons", "tsconfig.json", "tsconfig.build.json"],
  "scripts": {
    "generate": "bun run scripts/generate.ts",
    "build": "bun run generate && tsc -p tsconfig.build.json",
    "build:only": "tsc -p tsconfig.build.json"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "react": "^19.2.1",
    "typescript": "^6.0.3"
  }
}
